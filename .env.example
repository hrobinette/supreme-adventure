# Password required to access the authoring app (login screen).
APP_PASSWORD=OPS123

# --- Supabase (for cross-device shared snapshots) ---
# The app works without these (snapshots fall back to browser-local storage).
# Both are SERVER-ONLY — they are never sent to the browser.
# Find them in your Supabase project: Settings -> API.
#   SUPABASE_URL              = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" secret (NOT the anon key)
# Then create the snapshots table by running supabase/schema.sql.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

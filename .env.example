# Password required to access the authoring app (login screen).
APP_PASSWORD=OPS123

# --- Supabase (optional, for cross-device shared snapshots) ---
# The app works fully without these using local (browser) storage.
# When you're ready to persist/share snapshots across devices, create a
# Supabase project, add a `snapshots` table (id text primary key,
# created_at timestamptz, label text, deals jsonb), and fill these in.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
